<Window x:Class="RemotePCControl.App.RemoteDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Remote Desktop View" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="Black">
    <Grid Background="Black">
        <Image x:Name="DesktopImage" Stretch="Uniform"
               MouseMove="DesktopImage_MouseMove"
               MouseLeftButtonDown="DesktopImage_MouseLeftButtonDown"
               MouseLeftButtonUp="DesktopImage_MouseLeftButtonUp"
               MouseRightButtonDown="DesktopImage_MouseRightButtonDown"
               MouseRightButtonUp="DesktopImage_MouseRightButtonUp" />
    </Grid>
</Window>
