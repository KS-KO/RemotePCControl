<Window x:Class="RemotePCControl.App.Views.RemoteFileBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:RemotePCControl.App.ViewModels"
        xmlns:models="clr-namespace:RemotePCControl.App.Models"
        mc:Ignorable="d"
        Title="Remote File Explorer" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}">
    
    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <viewmodels:BooleanToIconConverter x:Key="BooleanToIconConverter" />
        <viewmodels:ProgressToVisibilityConverter x:Key="ProgressToVisibilityConverter" />
        <Style x:Key="CenteredColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Border Width="32" Height="32" CornerRadius="8" Background="#2563EB" Margin="0,0,12,0">
                    <TextBlock Text="📁" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="18"/>
                </Border>
                <TextBlock Style="{StaticResource HeaderTextStyle}" Text="Remote File Explorer" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="Refresh" HorizontalAlignment="Right" Command="{Binding BrowseRemoteFilesCommand}" Width="100"/>
        </DockPanel>

        <!-- Breadcrumbs Navigation -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding}" Foreground="#2563EB" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
                            <TextBlock Text=" › " Foreground="#94A3B8" Margin="8,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Download Progress Bar (Overlay or Dedicated row) -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" Height="3" Background="Transparent" Margin="2,0,2,14" Panel.ZIndex="10">
            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="3" Background="Transparent" BorderThickness="0" Foreground="#10B981"
                         Visibility="{Binding DownloadProgress, Converter={StaticResource ProgressToVisibilityConverter}}"/>
        </Border>

        <!-- File List -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
            <DataGrid x:Name="FileGrid"
                      ItemsSource="{Binding RemoteFiles}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      GridLinesVisibility="None" 
                      BorderThickness="0"
                      Background="Transparent"
                      RowHeight="45"
                      HeadersVisibility="Column">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding NavigateIntoFolderCommand}" 
                                  CommandParameter="{Binding SelectedItem, ElementName=FileGrid}"/>
                </DataGrid.InputBindings>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:FileEntry}">
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <TextBlock Text="{Binding IsDirectory, Converter={StaticResource BooleanToIconConverter}}" 
                                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#1E293B"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeLabel}" Width="120" ElementStyle="{StaticResource CenteredColumnStyle}"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="200" Foreground="#94A3B8"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer / Status -->
        <DockPanel Grid.Row="3" Margin="0,15,0,0">
            <TextBlock Text="{Binding TransferSummary}" Foreground="#64748B" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Download Selected" Background="#D81B60" Margin="0,0,10,0" Width="150" 
                        Command="{Binding DownloadSelectedFileCommand}" 
                        CommandParameter="{Binding SelectedItem, ElementName=FileGrid}"/>
                <Button Content="Close" Background="#64748B" Width="80" IsCancel="True" />
            </StackPanel>
        </DockPanel>
    </Grid>

</Window>
