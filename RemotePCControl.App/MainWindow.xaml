<Window x:Class="RemotePCControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:RemotePCControl.App.Models"
        mc:Ignorable="d"
        Title="Remote PC Control"
        Icon="Resources/AppIcon.png"
        Width="1440"
        Height="920"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    
    <Window.InputBindings>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteRemoteClipboardCommand}" />
    </Window.InputBindings>
    <Grid Background="{StaticResource SidebarBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="0,32,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo/Title -->
                    <RowDefinition Height="*" />    <!-- Nav Items -->
                    <RowDefinition Height="Auto" /> <!-- Resource Monitor -->
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Margin="24,0,24,48">
                    <TextBlock Text="REMOTE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="PC Control" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Navigation Group -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Click="Menu_Click" Tag="0" IsChecked="True" GroupName="Sidebar" />
                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Content="Devices" Click="Menu_Click" Tag="1" GroupName="Sidebar" />
                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Content="Active Session" Click="Menu_Click" Tag="2" GroupName="Sidebar" />
                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Content="Audit Timeline" Click="Menu_Click" Tag="3" GroupName="Sidebar" />
                </StackPanel>

                <!-- Resource Stats (Sidebar Bottom) -->
                <Border Grid.Row="2" Margin="16,0" Padding="20" Background="#1E293B" CornerRadius="16">
                    <StackPanel Margin="24">
                        <TextBlock Text="System Resources" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,16" />
                        
                        <StackPanel Margin="0,0,0,12">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="CPU: 3.6%" FontSize="12" Foreground="White" />
                            </Grid>
                            <ProgressBar Height="4" Value="3.6" Background="#0F172A" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Memory: 15.3 / 31.3 GB (48.9%)" FontSize="12" Foreground="White" />
                            </Grid>
                            <ProgressBar Height="4" Value="48.9" Background="#0F172A" Foreground="{StaticResource SuccessBrush}" BorderThickness="0" />
                        </StackPanel>
                        
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12" Opacity="0.3" />
                        <TextBlock Text="Commits: 8 | Hash: 7a794f564" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" Opacity="0.6" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="{StaticResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" /> <!-- Top Bar -->
                <RowDefinition Height="*" />  <!-- View Content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Padding="32,0" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Control Center" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,24,0" Foreground="White" />
                        <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="25" Padding="16,0,4,0" Height="50" Width="420">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding QuickConnectDeviceId, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" Margin="4,0" 
                                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                                         Padding="8,0" FontSize="14"
                                         ToolTip="장치 이름, 코드, 또는 ID를 입력하여 빠르게 연결하세요." />
                                <Button Grid.Column="1" Command="{Binding QuickConnectCommand}" Content="Connect" 
                                        Padding="16,0" Margin="4" FontSize="13" FontWeight="SemiBold"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1" VerticalAlignment="Center" Padding="16,8" CornerRadius="12" Background="{StaticResource AccentMutedBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource SubtleTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveSessionStatusColor}" Value="SuccessBrush">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActiveSessionStatusColor}" Value="WarningBrush">
                                                <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActiveSessionStatusColor}" Value="ErrorBrush">
                                                <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ActiveSessionStatus}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Switcher with Scrolling Support -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="32">
                    <!-- Group 0: Dashboard -->
                    <Grid x:Name="DashboardView">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMenuIndex}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Dashboard Overview" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,24" />

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,24">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Total Devices" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBlock Text="{Binding DeviceCount}" FontSize="48" FontWeight="Bold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Online Now" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBlock Text="{Binding OnlineDeviceCount}" FontSize="48" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Build Metadata" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBlock Text="{Binding BuildProfile}" FontWeight="SemiBold" Margin="0,12,0,0" Foreground="White" />
                                <TextBlock Text="{Binding ArchitectureProfile}" Margin="0,4,0,0" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBlock Text="{Binding UiArchitecture}" Margin="0,4,0,0" Foreground="{StaticResource SubtleTextBrush}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Recent Activity" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <ListBox Grid.Row="1" ItemsSource="{Binding SessionLogs}" Margin="0,0,-12,0" MaxHeight="480" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,12,12" Padding="16" Background="#0F172A" CornerRadius="12" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="4" Height="32" Background="{StaticResource AccentBrush}" CornerRadius="2" Margin="0,0,16,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White" />
                                                            <TextBlock Text="{Binding TimestampLabel}" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" />
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Quick Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <TextBlock Text="Approval Mode" Foreground="{StaticResource SubtleTextBrush}" />
                                    <ComboBox ItemsSource="{Binding ApprovalModes}" SelectedItem="{Binding SelectedApprovalMode}" />
                                    
                                    <TextBlock Text="Capture Rate" Foreground="{StaticResource SubtleTextBrush}" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding CaptureRates}" SelectedItem="{Binding SelectedCaptureRate}" DisplayMemberPath="Label" />

                                    <TextBlock Text="Compression" Foreground="{StaticResource SubtleTextBrush}" Margin="0,8,0,0" />
                                    <ComboBox ItemsSource="{Binding CompressionOptions}" SelectedItem="{Binding SelectedCompression}" DisplayMemberPath="Label" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Internet Relay (Beta)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <TextBlock Text="Relay Server IP" Foreground="{StaticResource SubtleTextBrush}" />
                                    <TextBox Text="{Binding RelayIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                                    
                                    <TextBlock Text="Relay Code (6 chars)" Foreground="{StaticResource SubtleTextBrush}" />
                                    <Grid Margin="0,4,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding RelayCode, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" HorizontalContentAlignment="Center" MaxLength="6" />
                                        <Button Grid.Column="1" Content="Start Host" Command="{Binding StartRelayHostCommand}" Margin="8,0,0,0" Padding="12,0" Background="{StaticResource SuccessBrush}" />
                                    </Grid>
                                    
                                    <Button Content="Connect via Relay" Command="{Binding ConnectViaRelayCommand}" Background="{StaticResource AccentBrush}" HorizontalAlignment="Stretch" />
                                    <TextBlock Text="인터넷 연결을 위해 릴레이 서버를 거쳐 통신합니다." 
                                               Foreground="{StaticResource SubtleTextBrush}" FontSize="11" 
                                               Margin="0,12,0,4" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                    <TextBlock Text="* 연결 성공 시 원격 화면 창이 별도로 열립니다." 
                                               Foreground="{StaticResource AccentMutedBrush}" FontSize="10" 
                                               Margin="0,0,0,8" HorizontalAlignment="Center" FontStyle="Italic" />
                                </StackPanel>
                            </Border>
                             

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Last Session Info" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="White" />
                                    <TextBlock Text="{Binding LastActionSummary}" TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Group 1: Devices -->
                <Grid x:Name="DevicesView">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMenuIndex}" Value="1">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Device Management" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,24" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,24,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Registered Devices" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                
                                <Border Grid.Row="1" Background="#0F172A" Padding="16" CornerRadius="12" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Add Manual Device (IP:Port)" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding ManualRegisterIP}" Margin="0,0,8,0" />
                                                <TextBox Grid.Column="1" Text="{Binding ManualRegisterPort}" />
                                            </Grid>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding RegisterManualDeviceCommand}" Content="Add" VerticalAlignment="Bottom" Height="38" Margin="12,0,0,0" />
                                    </Grid>
                                </Border>

                                <ListBox Grid.Row="2" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" Margin="0,0,-8,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,12" Padding="16" CornerRadius="12" Background="#0F172A" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" />
                                                        <TextBlock Text="{Binding DeviceId}" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Command="{Binding DataContext.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                CommandParameter="{Binding}"
                                                                Content="✕" 
                                                                Foreground="#EF4444" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                FontSize="14" 
                                                                Padding="8,4"
                                                                ToolTip="장치 삭제"
                                                                Margin="0,0,8,0" />
                                                        <Border Padding="12,4" CornerRadius="999" Background="{Binding StatusBrush}">
                                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Device Profile" />
                                        <Button DockPanel.Dock="Right" Padding="12,6" Background="{StaticResource WarningBrush}" 
                                                Command="{Binding ToggleFavoriteCommand}" Content="{Binding SelectedDeviceFavoriteLabel}" HorizontalAlignment="Right" />
                                    </DockPanel>
                                    
                                    <Border Margin="0,20,0,0" Padding="20" Background="#0F172A" CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedDevice.Name, TargetNullValue=Select a device}" FontSize="24" FontWeight="Bold" />
                                            <TextBlock Text="{Binding SelectedDevice.InternalGuid}" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding SelectedDevice.Description}" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Capabilities" FontWeight="SemiBold" Margin="0,24,0,12" />
                                    <ItemsControl ItemsSource="{Binding SelectedDevice.Capabilities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,8" Padding="12,6" CornerRadius="8" Background="{StaticResource AccentMutedBrush}">
                                                    <TextBlock Text="{Binding}" FontSize="12" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Margin="0,24,0,0" Padding="20" Background="#0F172A" CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock Text="Custom Metadata" FontWeight="SemiBold" Margin="0,0,0,12" />
                                            <TextBlock Text="Device Name" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" />
                                            <TextBox Text="{Binding EditDeviceName}" Margin="0,4,0,12" />
                                            <TextBlock Text="Description" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" />
                                            <TextBox Text="{Binding EditDeviceDescription}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Command="{Binding UpdateDeviceMetadataCommand}" Content="Save Changes" HorizontalAlignment="Stretch" />
                                                <Button Grid.Column="1" Command="{Binding RemoveDeviceCommand}" CommandParameter="{Binding SelectedDevice}" 
                                                        Content="Delete" Background="{StaticResource ErrorBrush}" Margin="8,0,0,0" HorizontalAlignment="Stretch" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Group 2: Active Session -->
                <Grid x:Name="SessionView">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMenuIndex}" Value="2">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Remote Session Activity" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,24" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Session Controls" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <TextBlock Text="{Binding ActiveSessionTitle}" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{Binding ActiveSessionDetail}" Foreground="{StaticResource SubtleTextBrush}" Margin="0,8,0,20" TextWrapping="Wrap" />
                                
                                <WrapPanel>
                                    <Button Command="{Binding DisconnectCommand}" Content="End Session" Background="{StaticResource ErrorBrush}" Margin="0,0,12,12" />
                                    <Button Command="{Binding LockRemoteSessionCommand}" Content="Lock Screen" Background="{StaticResource WarningBrush}" Margin="0,0,12,12" />
                                    <ToggleButton Style="{StaticResource QuickActionButtonStyle}" Content="Block Remote Input" IsChecked="{Binding IsRemoteInputBlocked}" Command="{Binding ToggleRemoteInputBlockCommand}" Margin="0,0,12,12" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Remote Features" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <UniformGrid Columns="2">
                                    <CheckBox Content="Clipboard sync" IsChecked="{Binding IsClipboardSyncEnabled}" Margin="0,0,0,12" Foreground="White" />
                                    <CheckBox Content="File copy (Ctrl+C/V)" IsChecked="{Binding IsCtrlCopyEnabled}" Margin="0,0,0,12" Foreground="White" />
                                    <CheckBox Content="Safe display placement" IsChecked="{Binding IsViewerPinnedToSafeDisplay}" Margin="0,0,0,12" Foreground="White" />
                                    <CheckBox Content="Local drive redirect" IsChecked="{Binding IsLocalDriveRedirectEnabled}" Margin="0,0,0,12" Foreground="White" />
                                    <CheckBox Content="Auto reconnect" IsChecked="{Binding IsReconnectEnabled}" Foreground="White" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Display &amp; Capture" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Source Display" Foreground="{StaticResource SubtleTextBrush}" />
                                        <ComboBox ItemsSource="{Binding CaptureDisplays}" SelectedItem="{Binding SelectedCaptureDisplay}" DisplayMemberPath="Label" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Viewer Window" Foreground="{StaticResource SubtleTextBrush}" />
                                        <ComboBox ItemsSource="{Binding ViewerDisplays}" SelectedItem="{Binding SelectedViewerDisplay}" DisplayMemberPath="Label" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Connection Quality" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <TextBlock Text="{Binding ConnectionQualitySummary}" FontSize="16" Margin="0,0,0,12" />
                                <ProgressBar Height="12" Maximum="100" Value="{Binding ConnectionQualityPercent}" Background="#0F172A" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="File Operations" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <Button Command="{Binding BrowseRemoteFilesCommand}" Content="Remote Explorer" Background="{StaticResource AccentMutedBrush}" HorizontalAlignment="Stretch" Margin="0,0,0,12" />
                                <Button Command="{Binding UploadFileCommand}" Content="Upload Local File" HorizontalAlignment="Stretch" Margin="0,0,0,12" />
                                <Button Command="{Binding PasteRemoteClipboardCommand}" Content="Paste Clipboard Files" Background="{StaticResource SuccessBrush}" HorizontalAlignment="Stretch" />
                                
                                <Border Margin="0,20,0,0" Padding="16" Background="#0F172A" CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock Text="Transfer Status" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding TransferSummary}" TextWrapping="Wrap" />
                                        
                                        <Grid Margin="0,12,0,0" Visibility="{Binding IsTransferActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Height="10" Maximum="100" Value="{Binding DownloadProgress}" Background="#1E293B" Foreground="{StaticResource SuccessBrush}" BorderThickness="0" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Command="{Binding CancelTransferCommand}" Content="Cancel" Padding="8,2" Margin="12,0,0,0" FontSize="11" Background="{StaticResource ErrorBrush}" Height="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,0" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Margin="0,20,0,0">
                                    <TextBlock Text="Download Path" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding DownloadPath}" IsReadOnly="True" FontSize="11" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Command="{Binding BrowseDownloadPathCommand}" Content="···" Padding="8,0" Margin="8,0,0,0" Height="28" Width="36" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Grid>
                </Grid>

                <!-- Group 3: Audit Timeline -->
                <Grid x:Name="TimelineView">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMenuIndex}" Value="3">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Activity Timeline &amp; Logs" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,24" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,24,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Recent Sessions" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding RecentConnections}" SelectedItem="{Binding SelectedRecentConnection}" Margin="0,0,-8,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,12" Padding="16" CornerRadius="12" Background="#0F172A" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" Foreground="White" />
                                                    <TextBlock Text="{Binding LastConnectedLabel}" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding DeviceCode}" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" />
                                                <Button Command="{Binding DataContext.UseRecentConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                        Content="Restore Setup" HorizontalAlignment="Stretch" Margin="0,12,0,0" Height="32" Padding="0" Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Full Audit Log" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding SessionLogs}" Margin="0,0,-12,0" MaxHeight="600" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12" Padding="20" Background="#0F172A" CornerRadius="16">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                                    <TextBlock Text="{Binding TimestampLabel}" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="{StaticResource SubtleTextBrush}" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Message}" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="14" />
                                                <TextBlock Text="{Binding Meta}" Margin="0,8,0,0" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Grid>
</Window>
