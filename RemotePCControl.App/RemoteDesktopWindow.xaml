<Window x:Class="RemotePCControl.App.RemoteDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Remote Desktop View" Height="720" Width="1280"
        Icon="Resources/AppIcon.png"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Cursor="Arrow"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Window.Resources>
        <Style x:Key="RemoteShortcutButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="BorderBrush" Value="#FF1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1E40AF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF172554" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#CC111827"
                Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                    <Border Margin="0,0,8,0" Padding="10,4" Background="#FF14532D" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Live Session" />
                    </Border>
                    <Border Margin="0,0,8,0" Padding="10,4" Background="#FF1E3A8A" CornerRadius="999">
                        <TextBlock Foreground="White" Text="Input Ready" />
                    </Border>
                    <Border Margin="0,0,8,0" Padding="10,4" Background="#FF374151" CornerRadius="999">
                        <TextBlock x:Name="CaptureDisplayBadge" Foreground="White" Text="Capture: Auto" />
                    </Border>
                    <Border Margin="0,0,8,0" Padding="10,4" Background="#FF374151" CornerRadius="999">
                        <TextBlock x:Name="ViewerDisplayBadge" Foreground="White" Text="Viewer: Auto" />
                    </Border>
                    <Border Padding="10,4" Background="#FF374151" CornerRadius="999">
                        <TextBlock x:Name="CompressionBadge" Foreground="White" Text="Compression: JPEG 85" />
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Text="Remote Shortcuts" />

                    <UniformGrid Grid.Column="1"
                                 Rows="1"
                                 Columns="6"
                                 HorizontalAlignment="Stretch">
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Content="Start"
                            Click="StartButton_Click" />
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Content="Run"
                            Click="RunButton_Click" />
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Content="Task Mgr"
                            Click="TaskManagerButton_Click" />
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Content="Alt+Tab"
                            Click="AltTabButton_Click" />
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Content="Esc"
                            Click="EscapeButton_Click" />
                    <Button Style="{StaticResource RemoteShortcutButtonStyle}"
                            Margin="0"
                            Content="Fullscreen"
                            Click="FullscreenButton_Click" />
                    </UniformGrid>
                </Grid>
            </Grid>
        </Border>

        <Image Grid.Row="1"
               x:Name="DesktopImage" Stretch="Uniform"
               Cursor="Arrow"
               MouseMove="DesktopImage_MouseMove"
               MouseLeftButtonDown="DesktopImage_MouseLeftButtonDown"
               MouseLeftButtonUp="DesktopImage_MouseLeftButtonUp"
               MouseRightButtonDown="DesktopImage_MouseRightButtonDown"
               MouseRightButtonUp="DesktopImage_MouseRightButtonUp" />
    </Grid>
</Window>
